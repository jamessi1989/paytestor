# Crewqa env template — copy to .env and fill in real values.
# Never commit real secrets.

# ---------- Database (Neon / Postgres) ----------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
# Used by Prisma Migrate for schemas that need a direct (non-pooled) connection.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ---------- Supabase (Auth only; Postgres lives in Neon) ----------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---------- Stripe (dev payments + Identity) ----------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ---------- Tremendous (tester payouts) ----------
TREMENDOUS_API_KEY=""
TREMENDOUS_CAMPAIGN_ID=""
TREMENDOUS_WEBHOOK_SECRET=""

# ---------- Resend (transactional email) ----------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Crewqa <hello@crewqa.com>"

# ---------- Cloudflare R2 (screen recording storage) ----------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# ---------- Inngest (workflow engine) ----------
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ---------- Anthropic (LLM-assisted QA) ----------
ANTHROPIC_API_KEY=""

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
