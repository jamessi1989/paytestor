# Crewqa env template — copy to .env and fill in real values.
# Never commit real secrets.

# ---------- Database (local Postgres in Docker) ----------
# `pnpm db:up` spins up a Postgres container on 127.0.0.1:5435.
# Prod mounts its own Postgres per DEPLOY-ON-BOTVIEW-SERVER.md.
DATABASE_URL="postgresql://crewqa:crewqa@127.0.0.1:5435/crewqa?schema=public"
DIRECT_DATABASE_URL="postgresql://crewqa:crewqa@127.0.0.1:5435/crewqa?schema=public"

# ---------- Auth.js v5 (NextAuth) ----------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URI: http://<host>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub OAuth — https://github.com/settings/developers
# Callback URL:  http://<host>/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ---------- Stripe (dev payments + Identity) ----------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ---------- Tremendous (tester payouts) ----------
TREMENDOUS_API_KEY=""
TREMENDOUS_CAMPAIGN_ID=""
TREMENDOUS_WEBHOOK_SECRET=""

# ---------- Resend (transactional email) ----------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Crewqa <hello@crewqa.com>"

# ---------- Cloudflare R2 (screen recording storage) ----------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# ---------- Inngest (workflow engine) ----------
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ---------- Anthropic (LLM-assisted QA) ----------
ANTHROPIC_API_KEY=""

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
